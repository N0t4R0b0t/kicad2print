{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build (release)",
      "type": "shell",
      "command": "cargo build --release",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": "$rustc"
    },
    {
      "label": "Build (debug)",
      "type": "shell",
      "command": "cargo build",
      "group": "build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": "$rustc"
    },
    {
      "label": "Test",
      "type": "shell",
      "command": "cargo test",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": "$rustc"
    },
    {
      "label": "Test (with output)",
      "type": "shell",
      "command": "cargo test -- --nocapture",
      "group": "test",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": "$rustc"
    },
    {
      "label": "Clippy",
      "type": "shell",
      "command": "cargo clippy --all-targets -- -D warnings",
      "group": "build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": {
        "owner": "clippy",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(error|warning)(?:\\[([^\\]]+)\\])?: (.+)$",
          "severity": 1,
          "code": 2,
          "message": 3
        }
      }
    },
    {
      "label": "Clean",
      "type": "shell",
      "command": "cargo clean",
      "group": "build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Install (MCP binary)",
      "type": "shell",
      "command": "cargo install --path . --force",
      "group": "build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": "$rustc"
    }
  ]
}
